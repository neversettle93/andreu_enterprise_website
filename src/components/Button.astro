---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "inverse";
  type?: "button" | "submit";
  class?: string;
}

const { href, variant = "primary", type = "button", class: className } = Astro.props;

const base = "inline-block rounded-full px-8 py-3.5 text-sm font-medium";
const variants = {
  primary: "bg-navy-900 text-white hover:bg-cobalt-600",
  secondary: "border border-navy-200 text-navy-900 hover:border-cobalt-500 hover:text-cobalt-600",
  inverse: "bg-white text-navy-900 hover:bg-cyan-300",
};
---

{
  href ? (
    <a href={href} class:list={[base, variants[variant], className]}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={[base, variants[variant], className]}>
      <slot />
    </button>
  )
}
