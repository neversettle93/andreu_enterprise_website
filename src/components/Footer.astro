---
const year = new Date().getFullYear();
---

<footer class="border-t border-navy-200/60 bg-white">
  <div class="mx-auto max-w-6xl px-6 py-10 text-sm text-navy-600">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div class="flex items-center gap-2">
        <img src="/brand/icon-color.svg" alt="" class="h-5 w-5" width="100" height="100" />
        <span class="font-medium text-navy-700">
          Andreu Enterprise <span class="text-cobalt-600">Technology</span>
        </span>
      </div>
      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        <li><a href="/services" class="hover:text-cobalt-600">Services</a></li>
        <li><a href="/about" class="hover:text-cobalt-600">About</a></li>
        <li><a href="/case-studies" class="hover:text-cobalt-600">Case Studies</a></li>
        <li><a href="/contact" class="hover:text-cobalt-600">Contact</a></li>
      </ul>
    </div>
    <p class="mt-6">&copy; {year} Andreu Enterprise Technology LLC. Miami, FL.</p>
  </div>
</footer>
