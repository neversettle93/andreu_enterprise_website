---
const links = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/case-studies", label: "Case Studies" },
];
const currentPath = Astro.url.pathname;
---

<header class="border-b border-navy-200/60 bg-white/90 backdrop-blur">
  <nav
    class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-6 gap-y-3 px-6 py-5"
    aria-label="Primary"
  >
    <a href="/" class="flex items-center gap-2.5" aria-label="Andreu Enterprise Technology — home">
      <img src="/brand/icon-color.svg" alt="" class="h-8 w-8" width="100" height="100" />
      <span class="text-lg font-semibold tracking-tight text-navy-900">
        Andreu Enterprise <span class="text-cobalt-600">Technology</span>
      </span>
    </a>
    <ul class="order-3 flex w-full flex-wrap items-center gap-x-7 gap-y-2 font-mono text-xs uppercase tracking-wide text-navy-700 md:order-none md:w-auto">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="hover:text-cobalt-600"
              aria-current={currentPath === link.href ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="/contact"
      class="rounded-full bg-navy-900 px-5 py-2.5 text-sm font-medium text-white hover:bg-cobalt-600"
    >
      Get in touch
    </a>
  </nav>
</header>
