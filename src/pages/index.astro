---
import BaseLayout from "../layouts/BaseLayout.astro";
import GridSection from "../components/GridSection.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import ServiceCard from "../components/ServiceCard.astro";

const services = [
  {
    index: "01",
    title: "RevOps Implementation",
    description:
      "End-to-end Revenue Operations architecture in HubSpot: pipeline design, workflow automation, a shared data dictionary, revenue reporting, and renewal-cycle automation.",
  },
  {
    index: "02",
    title: "CRM Setup & Migration",
    description:
      "Data migration strategy, property architecture, conditional logic, and a sales-team adoption plan — including two-pipeline setups covering new business and post-sale/renewal.",
  },
  {
    index: "03",
    title: "AI & Automation Consulting",
    description:
      "Automation workflows built in n8n and AI tooling woven into day-to-day operations, plus AI-assisted BI dashboards for multi-country revenue reporting and data consolidation.",
  },
  {
    index: "04",
    title: "IT Management for SaaS",
    description:
      "Identity and access (Microsoft Entra ID), networking, security, technical support, Microsoft 365 administration, and collaboration tooling for growing SaaS teams.",
  },
];

const stats = [
  { value: "20+", label: "Countries covered in revenue reporting" },
  { value: "18+", label: "Automated workflows shipped in a single CRM build" },
  { value: "100", label: "Spreadsheets consolidated into one source of truth" },
  { value: "05", label: "Phases in the RevOps implementation framework" },
];
---

<BaseLayout
  title="RevOps & AI Automation for B2B SaaS"
  description="Andreu Enterprise Technology helps mid-market B2B companies design Revenue Operations, migrate CRMs, and automate with AI — built and tested in a live, multi-country SaaS environment."
>
  <GridSection border class="grid gap-12 pt-24 pb-20 lg:grid-cols-12 lg:gap-8">
    <div class="lg:col-span-7">
      <Eyebrow text="Revenue Operations & AI Automation" />
      <h1 class="mt-6 text-6xl font-semibold leading-[0.95] tracking-tight text-navy-900 sm:text-7xl">
        Revenue strategy.<br />
        <span class="text-cobalt-600">Built and shipped.</span>
      </h1>
      <p class="mt-8 max-w-xl text-lg text-navy-600 leading-relaxed">
        Andreu Enterprise Technology designs and implements RevOps
        architecture, CRM systems, and AI-driven automation for mid-market
        B2B companies — grounded in the operating reality of a live,
        multi-country SaaS business, not theory.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href="/contact" variant="primary">Start a conversation</Button>
        <Button href="/case-studies" variant="secondary">See case studies</Button>
      </div>
    </div>

    <div class="lg:col-span-5 lg:pt-2">
      <div class="rounded-2xl border border-navy-200/60 bg-white/80 p-2 backdrop-blur">
        <ul class="divide-y divide-navy-200/60">
          {
            services.map((service) => (
              <li class="flex items-baseline gap-4 px-5 py-4">
                <span class="font-mono text-sm text-cobalt-600">{service.index}</span>
                <span class="text-navy-800">{service.title}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </GridSection>

  <section class="border-b border-navy-200/60">
    <div class="mx-auto grid max-w-6xl grid-cols-2 divide-x divide-y divide-navy-200/60 px-6 sm:grid-cols-4 sm:divide-y-0">
      {
        stats.map((stat) => (
          <div class="px-6 py-10 first:pl-0">
            <p class="font-mono text-4xl font-semibold tracking-tight text-navy-900 sm:text-5xl">{stat.value}</p>
            <p class="mt-2 text-sm text-navy-600 leading-snug">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <GridSection variant="dark" class="py-24">
    <p class="max-w-3xl text-2xl text-white leading-snug sm:text-3xl">
      Most consultants can talk about revenue strategy, or they can talk
      about implementation. Few can do both — design a pipeline
      architecture with a CRO in the morning, then configure the CI/CD
      permissions or the Power BI dashboard that reports on it in the
      afternoon.
    </p>
    <p class="mt-6 max-w-xl text-navy-400">
      AI is used as a genuine capability multiplier here, not a shortcut —
      it's what lets one person deliver outcomes that would otherwise
      require a larger team.
    </p>
  </GridSection>

  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="flex items-end justify-between gap-6">
      <h2 class="text-4xl font-semibold tracking-tight text-navy-900">Services</h2>
      <a href="/services" class="text-sm font-medium text-cobalt-600 hover:underline">
        View all services
      </a>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {services.map((service) => <ServiceCard {...service} />)}
    </div>
  </section>
</BaseLayout>
